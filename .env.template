# VespAI Configuration
# Copy to .env and customize for your setup

# SMS Alert Configuration (Optional)
# LOX24_API_KEY=your_api_key_here
# PHONE_NUMBER=+1234567890
# DOMAIN_NAME=your-domain.com

# Model Configuration
# Use ONNX by default so startup does not require NCNN/PyTorch runtime.
MODEL_PATH=models/L2_2026-03-25_13-42-18_best.onnx
VESPAI_MODEL_FORMAT=onnx
VESPAI_CLASS_MAP=0:Unknown,1:Bees,2:crabro,3:velutina
VESPAI_DATASET_PATH="datasets/test"

# Camera Configuration
# Legacy single-camera vars are supported but intentionally omitted here.
# Primary camera profile vars are camera1/camera2.

# Camera 1 (active)
VESPAI_CAMERA1_SOURCE=usb
VESPAI_CAMERA1_DEVICE=/dev/video8
VESPAI_CAMERA1_AUTOFOCUS=true
VESPAI_CAMERA1_ALIAS="Camera 1"

# Camera 2 (enable for dual-camera mode)
VESPAI_CAMERA2_ENABLED=true
VESPAI_CAMERA2_SOURCE=picamera2
VESPAI_CAMERA2_DEVICE=
VESPAI_CAMERA2_AUTOFOCUS=true
VESPAI_CAMERA2_ALIAS="Front Camera"

# Global autofocus fallback for cameras without an explicit per-camera value.
VESPAI_CAMERAPI_AUTOFOCUS=true
# Pi Camera Module tuning (Picamera2 only)
VESPAI_CAMERAPI_FOCUS_MODE=manual
VESPAI_CAMERAPI_FOCUS_DISTANCE_M=0.13
# AWB MODE = 
#auto
#incandescent
#tungsten
#fluorescent
#indoor
#daylight
#cloudy
#off
#custom
#manual
VESPAI_CAMERAPI_AWB_MODE=auto
VESPAI_CAMERAPI_AWB_RED_GAIN=0.0
VESPAI_CAMERAPI_AWB_BLUE_GAIN=0.0
VESPAI_CAMERAPI_COLOR_ORDER=bgr
WEB_COLOR_SCALE_R=1.0
WEB_COLOR_SCALE_G=1.0
WEB_COLOR_SCALE_B=1.0

# Tracking mode: off | centroid | iou
VESPAI_TRACKING_MODE=iou

# USB dual-camera example
# VESPAI_CAMERA1_SOURCE=usb
# VESPAI_CAMERA1_DEVICE=/dev/video0
# VESPAI_CAMERA2_ENABLED=true
# VESPAI_CAMERA2_SOURCE=usb
# VESPAI_CAMERA2_DEVICE=/dev/video1

# PiCamera + USB example
# VESPAI_CAMERA1_SOURCE=picamera2
# VESPAI_CAMERA1_DEVICE=
# VESPAI_CAMERA2_ENABLED=true
# VESPAI_CAMERA2_SOURCE=usb
# VESPAI_CAMERA2_DEVICE=/dev/video0
RESOLUTION=1280x720
CAMERA_RESOLUTION=1280x720
CAMERA_FPS=30

# Detection Configuration
CONFIDENCE_THRESHOLD=0.66
SAVE_DETECTIONS=true
SAVE_DIRECTORY=monitor/detections
DETECTION_RETENTION_DAYS=21
DETECTION_MAX_FILE_COUNT=250
FRAME_DELAY=0.35
# Seconds to wait before advancing to the next dataset frame
DATASET_FRAME_DELAY=5.0
VESPAI_CAMERA1_MIN_INFER_INTERVAL=0.0
VESPAI_CAMERA2_MIN_INFER_INTERVAL=0.4

# Motion Detection (Optional)
ENABLE_MOTION_DETECTION=true
MIN_MOTION_AREA=5000

# Web Interface
WEB_HOST=0.0.0.0
WEB_PORT=8081
WEB_PREVIEW_SIZE=960x540
LIVE_STREAM_QUALITY=72
CURRENT_FRAME_QUALITY=82
